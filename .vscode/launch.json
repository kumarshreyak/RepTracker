{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Frontend (React Native)",
            "type": "reactnative",
            "request": "launch",
            "platform": "exponent",
            "cwd": "${workspaceFolder}/frontend-native",
            "expoHostType": "lan",
            "enableDebug": true,
            "console": "integratedTerminal"
        },
        {
            "name": "Launch Frontend (React Native) - Web",
            "type": "reactnative",
            "request": "launch",
            "platform": "exponent",
            "cwd": "${workspaceFolder}/frontend-native",
            "expoHostType": "lan",
            "enableDebug": true,
            "console": "integratedTerminal"
        },
        {
            "name": "Launch Frontend (Expo iOS)",
            "type": "node-terminal", 
            "request": "launch",
            "command": "npx expo run:ios",
            "cwd": "${workspaceFolder}/frontend-native",
            "console": "integratedTerminal",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        },
        {
            "name": "Attach to React Native (Metro)",
            "type": "reactnative",
            "request": "attach",
            "cwd": "${workspaceFolder}/frontend-native",
            "port": 8081,
            "enableDebug": true
        },
        {
            "name": "Launch Backend (Go)",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/backend/cmd/server/main.go",
            "cwd": "${workspaceFolder}/backend",
            "console": "integratedTerminal",
            "env": {},
            "args": [],
            "showLog": true
        },
        {
            "name": "Launch Both (Frontend + Backend)",
            "type": "reactnative",
            "request": "launch",
            "platform": "exponent",
            "cwd": "${workspaceFolder}/frontend-native",
            "expoHostType": "lan",
            "enableDebug": true,
            "console": "integratedTerminal",
            "preLaunchTask": "start-backend"
        }
    ],
    "compounds": [
        {
            "name": "Launch Full Stack",
            "configurations": [
                "Launch Backend (Go)",
                "Launch Frontend (React Native)"
            ],
            "stopAll": true,
            "presentation": {
                "hidden": false,
                "group": "GymLog",
                "order": 1
            }
        },
        {
            "name": "Launch Full Stack (Web)",
            "configurations": [
                "Launch Backend (Go)",
                "Launch Frontend (React Native) - Web"
            ],
            "stopAll": true,
            "presentation": {
                "hidden": false,
                "group": "GymLog",
                "order": 2
            }
        }
    ]
}